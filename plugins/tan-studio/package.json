{
  "name": "@tan-studio/codex-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "contract:generate": "openapi-typescript ../../apps/web/src/generated/openapi.json -o src/generated/api.ts",
    "smoke": "bun run build && bun run scripts/smoke.ts",
    "test": "bun test",
    "test:e2e": "bun run scripts/e2e.ts",
    "test:live": "bun run scripts/live.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.9.3"
  }
}
