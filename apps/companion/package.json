{
  "name": "@tan-studio/companion",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --target=bun --outdir=dist/src",
    "dev": "cargo build --locked --manifest-path ../serial-bridge/Cargo.toml && bun --watch src/dev.ts",
    "start": "bun src/index.ts",
    "db:migrate": "bun src/db/migrate.ts",
    "db:seed": "bun src/db/seed-cli.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@tan-studio/api-contract": "workspace:*",
    "@tan-studio/application": "workspace:*",
    "@tan-studio/device-sassi": "workspace:*",
    "@tan-studio/native-format-adapters": "workspace:*",
    "hono": "^4.10.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/bun": "^1.2.22",
    "typescript": "^5.9.3"
  }
}
